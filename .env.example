# Server
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok.io

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_saas
# DATABASE_SSL_REJECT_UNAUTHORIZED=false # Set to false ONLY in local dev if using self-signed certs
# DB_POOL_MAX=10

# WhatsApp Cloud API (Meta)
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_permanent_access_token
WA_VERIFY_TOKEN=your_custom_verify_string
WA_APP_SECRET=your_app_secret
WA_API_VERSION=v19.0

# Instagram Messaging (Meta) — end-customer DM channel (browsing, cart,
# checkout). Merchant SaaS billing stays WhatsApp-only.
# Per-tenant credentials live in businesses.ig_business_account_id /
# ig_page_access_token; these env vars are the platform-level fallback,
# exactly like WA_PHONE_NUMBER_ID / WA_ACCESS_TOKEN above.
IG_BUSINESS_ACCOUNT_ID=your_ig_business_account_id
IG_ACCESS_TOKEN=your_ig_page_access_token
IG_APP_SECRET=your_ig_app_secret
# Webhook GET verification token for /api/webhooks/instagram (falls back to
# WA_VERIFY_TOKEN when unset).
IG_VERIFY_TOKEN=your_custom_verify_string
# IG_API_VERSION=v19.0

# Approved Meta message templates (business-initiated messages outside the
# 24-hour window are ONLY deliverable as templates). Create these in
# WhatsApp Manager > Message templates, then set each template's name here.
# When unset, the app falls back to free-form text (works only inside the
# 24h window). Body params, in order:
#   WA_TPL_RENEWAL_REMINDER      {{1}}=plan {{2}}=days_left {{3}}=amount
#   WA_TPL_SUSPENSION            {{1}}=business_name
#   WA_TPL_SUBSCRIPTION_RECEIPT  {{1}}=plan {{2}}=amount {{3}}=next_billing_date
#   WA_TPL_NEW_ORDER             {{1}}=order_no {{2}}=customer {{3}}=items {{4}}=total {{5}}=address
#   WA_TPL_TRIAL_REMINDER        {{1}}=business_name {{2}}=end_date {{3}}=days_left
#   WA_TPL_TRIAL_EXPIRED         {{1}}=business_name
# WA_TEMPLATE_LANG=en
# WA_TPL_RENEWAL_REMINDER=
# WA_TPL_SUSPENSION=
# WA_TPL_SUBSCRIPTION_RECEIPT=
# WA_TPL_NEW_ORDER=
# WA_TPL_TRIAL_REMINDER=
# WA_TPL_TRIAL_EXPIRED=
# WA_TPL_BROADCAST                 {{1}}=message_body (merchant re-engagement blasts)
# WA_TPL_BROADCAST=

# Paystack (customer checkout: cards + MoMo in one hosted flow)
PAYSTACK_SECRET_KEY=sk_test_xxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxx

# pawaPay (SaaS subscription billing: server-initiated MoMo collections)
# Configure {PUBLIC_BASE_URL}/api/payments/pawapay/callback as the deposit
# callback URL in the pawaPay dashboard.
PAWAPAY_API_TOKEN=your_api_token
# Defaults to the sandbox. Set explicitly for production:
# PAWAPAY_BASE_URL=https://api.pawapay.io

# Hubtel (legacy — only needed to receive callbacks for charges initiated
# before the pawaPay switch; safe to remove once none are pending)
HUBTEL_CLIENT_ID=your_client_id
HUBTEL_CLIENT_SECRET=your_client_secret
HUBTEL_MERCHANT_ACCOUNT_NUMBER=your_merchant_account
HUBTEL_WEBHOOK_SECRET=your_webhook_secret

# Clerk (merchant dashboard sign-in/sign-up — public/dashboard.html)
# Publishable key is safe client-side and is already hardcoded in dashboard.html.
# The secret key is server-only — get it from https://dashboard.clerk.com > WA-B > API keys.
CLERK_SECRET_KEY=your_clerk_secret_key

# SaaS Config
SUPPORT_WHATSAPP_NUMBER=+233241234567
DEFAULT_TRIAL_DAYS=14
SUSPENSION_GRACE_DAYS=3

# Payment sweeper (reconciles stuck pending payments)
# PAYMENT_PENDING_TTL_MINUTES=15
# PAYMENT_HARD_EXPIRE_HOURS=24
# STALE_ORDER_HOURS=48

# Data retention (weekly prune job)
# WEBHOOK_RETENTION_DAYS=30
# MESSAGE_LOG_RETENTION_DAYS=90

# Logging
LOG_LEVEL=info

# Ops alerting — texts this number on your own WhatsApp platform line
# (WA_PHONE_NUMBER_ID above) whenever an uncaught exception, unhandled
# rejection, or a webhook that exhausted all retries happens. Throttled to
# one alert per 5 minutes so a crash loop can't spam you. Unset = disabled.
# OPS_ALERT_PHONE=+233241234567

# Nightly DB backup (pg_dump -> gzip -> object storage) at 03:15 Africa/Accra.
# Requires the `pg_dump` binary on the host. DB_BACKUP_UPLOAD_CMD is a shell
# command with a {file} placeholder — bring your own CLI (aws s3, rclone,
# scp...). Both must be set or nothing is actually persisted; an alert fires
# if DB_BACKUP_ENABLED=true but no upload command is configured.
# DB_BACKUP_ENABLED=true
# DB_BACKUP_UPLOAD_CMD=aws --endpoint-url=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com s3 cp {file} s3://<bucket>/db-backups/

# Multi-instance deployment (set on every API replica EXCEPT one, or run a
# dedicated `npm run worker` process and set both to false on every API replica).
# When unset, both default to true so a single-process deploy works out of the box.
# RUN_CRON=false
# RUN_PROCESSOR=false
# PROCESSOR_INTERVAL_MS=1500
